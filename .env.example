# ==========================================
# LifeLink Configuration - Environment Variables
# ==========================================

# ----------------------------
# Backend Configuration
# ----------------------------
PORT=5000
NODE_ENV=development # Options: development, production, test

# Database Connection (MongoDB)
MONGODB_URI=mongodb://localhost:27017/lifelink
MONGO_URI=mongodb://localhost:27017/lifelink # Alias/Alternative database URL
DATABASE_URL=mongodb://localhost:27017/lifelink # Alias/Alternative database URL

# Frontend URLs & CORS Origins
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173 # Alias/Alternative client URL
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173 # Comma-separated list of allowed origins

# JWT Secrets & Expirations
JWT_SECRET=your_jwt_access_secret_key_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cryptography / Aadhaar Encryption
ENCRYPTION_KEY=f1a8b9c8d7e6f5a4b3c2d1e0f9a8b7c6 # Must be exactly 32 bytes (64 hex characters)

# Logging Level
LOG_LEVEL=info # Options: debug, info, warn, error

# ----------------------------
# Third-Party Integrations
# ----------------------------

# Email Service (SMTP / Nodemailer)
EMAIL_PROVIDER=smtp # Options: smtp, log
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="LifeLink Platform" <no-reply@lifelink.org>

# SMS OTP Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=your_twilio_phone_number_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Image Uploads (Cloudinary - optional/if applicable)
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret

# Social Auth / OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session Secret (Optional / Session backup)
SESSION_SECRET=your_session_secret_here

# ----------------------------
# Frontend Configuration (Vite)
# ----------------------------
# Note: Vite environment variables must be prefixed with VITE_ to be exposed to client-side code.
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
